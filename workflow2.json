    {
      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n  const deadlineStr = item.json.deadline; \n  \n  const todayStr = $node[\"Date & Time\"].json.currentDate; \n\n  if (deadlineStr) {\n    const deadlineDate = new Date(deadlineStr);\n    const todayDate = new Date(todayStr);\n    \n    const diffTime = deadlineDate - todayDate;\n    \n    const daysLeft = Math.ceil(diffTime / (1000 * 60 * 60 * 24));\n    \n    item.json.daysLeft = daysLeft;\n  } else {\n    item.json.daysLeft = null;\n  }\n}\n\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        624,
        -80
      ],
      "id": "91c7f893-6229-4685-8271-5ced6026ceaa",
      "name": "Code Days_left"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// 1. Đếm xem nhân viên này có bao nhiêu task (dựa vào độ dài của mảng)\nconst taskCount = item.json.appended_days_left ? item.json.appended_days_left.length : 0;\nlet tableRows = \"\";\n\n// 2. Vòng lặp để tạo từng hàng (thẻ <tr>) cho bảng\nfor (let i = 0; i < taskCount; i++) {\n  // Lấy dữ liệu từng cột, nếu cột nào lỡ bị trống thì để chữ \"Chưa có thông tin\"\n  const taskName = item.json.appended_task_name ? item.json.appended_task_name[i] : \"Chưa có tên\";\n  const priority = item.json.appended_priority_label ? item.json.appended_priority_label[i] : \"\";\n  const deadline = item.json.appended_deadline_text ? item.json.appended_deadline_text[i] : \"\";\n  const daysLeft = item.json.appended_days_left ? item.json.appended_days_left[i] : \"\";\n\n  // Lắp dữ liệu vào các ô (thẻ <td>)\n  tableRows += `\n    <tr>\n      <td style=\"border: 1px solid #ddd; padding: 10px;\">${taskName}</td>\n      <td style=\"border: 1px solid #ddd; padding: 10px; text-align: center;\">${priority}</td>\n      <td style=\"border: 1px solid #ddd; padding: 10px; text-align: center;\">${deadline}</td>\n      <td style=\"border: 1px solid #ddd; padding: 10px; color: #d9534f; font-weight: bold; text-align: center;\">${daysLeft}</td>\n    </tr>\n  `;\n}\n\n// 3. Bọc tất cả các hàng vào một khung bảng (thẻ <table>) hoàn chỉnh\nitem.json.htmlTable = `\n  <div style=\"font-family: Arial, sans-serif; max-width: 650px; border: 1px solid #e0e0e0; padding: 20px; border-radius: 8px;\">\n    <h2 style=\"color: #2c3e50; border-bottom: 2px solid #e74c3c; padding-bottom: 10px; margin-top: 0;\">\n      🚨 CÔNG VIỆC SẮP TỚI HẠN\n    </h2>\n    <p style=\"font-size: 15px; color: #333;\">Chào bạn,</p>\n    <p style=\"font-size: 15px; color: #333;\">Dưới đây là danh sách các công việc chỉ còn <strong>0-3 ngày</strong> nữa là tới hạn. Vui lòng kiểm tra và xử lý:</p>\n    \n    <table style=\"width: 100%; border-collapse: collapse; margin-top: 15px; font-size: 14px;\">\n      <thead>\n        <tr style=\"background-color: #f8f9fa; color: #333;\">\n          <th style=\"border: 1px solid #ddd; padding: 10px; text-align: left;\">Tên công việc</th>\n          <th style=\"border: 1px solid #ddd; padding: 10px; text-align: center;\">Mức độ</th>\n          <th style=\"border: 1px solid #ddd; padding: 10px; text-align: center;\">Hạn chót</th>\n          <th style=\"border: 1px solid #ddd; padding: 10px; text-align: center;\">Tình trạng</th>\n        </tr>\n      </thead>\n      <tbody>\n        ${tableRows}\n      </tbody>\n    </table>\n    \n    <p style=\"margin-top: 25px; font-size: 12px; color: #999; text-align: center;\">\n      <i>Hệ thống nhắc việc tự động từ n8n.</i>\n    </p>\n  </div>\n`;\n\n// Trả kết quả đi tiếp\nreturn item;"
      },
