    {
      "parameters": {
        "jsCode": "// 1. Lấy TOÀN BỘ danh sách nhân viên từ Node 'Set - Email Data'\nconst allEmployees = $('Set - Email Data').all();\nconst finalTaskList = [];\n\n// 2. Vòng lặp 1: Duyệt qua từng nhân viên (Nam, Hoa, Bình...)\nfor (const employee of allEmployees) {\n  const taskIds = employee.json.appended_task_id;\n  \n  // Kiểm tra xem người này có danh sách task không\n  if (taskIds && Array.isArray(taskIds)) {\n    \n    // 3. Vòng lặp 2: Duyệt qua từng task của nhân viên đó\n    for (const id of taskIds) {\n      // Đẩy từng task lẻ vào danh sách tổng\n      finalTaskList.push({\n        json: {\n          task_id_to_update: id,\n          processed_at: new Date().toISOString() // Thêm thời gian để tí ghi vào Sheet cho chuẩn\n        }\n      });\n    }\n  }\n}\n\n// 4. Trả về danh sách phẳng (ví dụ: 2 người, mỗi người 3 task -> trả về 6 items lẻ)\nreturn finalTaskList;"
      },
